/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    OmicsFlow — Nextflow Configuration
    Author  : Sory Millimono
    Version : 1.0.0
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// ── MANIFEST ────────────────────────────────────────────────────────────────
manifest {
    name            = 'OmicsFlow'
    author          = 'Sory Millimono'
    homePage        = 'https://github.com/Millimono/OmicsFlow'
    description     = 'Modular NGS pipeline: RNA-seq, Long-read, Metagenomics'
    mainScript      = 'workflows/rnaseq.nf'
    nextflowVersion = '!>=22.10.0'
    version         = '1.0.0'
    doi             = ''
}

// ── DEFAULT PARAMETERS ───────────────────────────────────────────────────────
params {
    max_cpus   = 8
    max_memory = '32.GB'
    max_time   = '24.h'
    outdir     = 'results'
}

// ── PROCESS LABELS ───────────────────────────────────────────────────────────
process {
    cpus   = 1
    memory = '6.GB'
    time   = '4.h'

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    withLabel: process_single {
        cpus   = 1
        memory = '6.GB'
        time   = '4.h'
    }
    withLabel: process_medium {
        cpus   = 4
        memory = '12.GB'
        time   = '8.h'
    }
    withLabel: process_high {
        cpus   = 8
        memory = '32.GB'
        time   = '16.h'
    }
}

// ── EXECUTION PROFILES ───────────────────────────────────────────────────────
profiles {

    // ── Local machine with Docker ─────────────────────────────────────────
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
        conda.enabled          = false
        process.executor       = 'local'
    }

    // ── Local machine with Singularity ────────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
        process.executor       = 'local'
    }

    // ── HPC cluster — SLURM ───────────────────────────────────────────────
    cluster {
        process.executor       = 'slurm'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process.queue          = 'normal'
        params.max_cpus        = 32
        params.max_memory      = '128.GB'
        params.max_time        = '72.h'
    }

    // ── AWS Batch ─────────────────────────────────────────────────────────
    cloud {
        process.executor       = 'awsbatch'
        aws.region             = 'ca-central-1'
        aws.batch.cliPath      = '/home/ec2-user/miniconda/bin/aws'
        docker.enabled         = true
        params.max_cpus        = 16
        params.max_memory      = '64.GB'
    }

    // ── Test profile (mini-datasets, CI/CD) ───────────────────────────────
    test {
        params.input           = "${projectDir}/data/test/samplesheet.csv"
        params.genome          = 'GRCh38_chr22'
        params.outdir          = 'results_test'
        params.max_cpus        = 2
        params.max_memory      = '6.GB'
        params.max_time        = '1.h'
        docker.enabled         = true
    }

    // ── CI stub (no real tools needed) ────────────────────────────────────
    stub {
        params.input           = "${projectDir}/data/test/samplesheet.csv"
        process.executor       = 'local'
        params.max_cpus        = 1
        params.max_memory      = '2.GB'
    }
}

// ── REPORTING ────────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
    overwrite = true
}


